{
  "name": "mercadona-claude-extension",
  "version": "0.1.0",
  "description": "Shop at Mercadona from Claude: search the catalog, fill and review your real cart, reorder past shops, and see products as a photo grid. You sign in in a browser and pay in the Mercadona app.",
  "type": "module",
  "main": "dist/server.mjs",
  "scripts": {
    "build": "esbuild src/server.mjs --bundle --platform=node --format=esm --target=node18 --outfile=dist/server.mjs --external:playwright-core --loader:.md=text",
    "start": "node dist/server.mjs",
    "pack": "npm run build && npx @anthropic-ai/mcpb pack"
  },
  "keywords": [
    "mercadona",
    "grocery",
    "groceries",
    "shopping",
    "supermarket",
    "cart",
    "reorder",
    "spain",
    "mcp",
    "claude",
    "claude-desktop"
  ],
  "author": "Igor Safonov (https://github.com/igorsafonov-gif)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright-core": "^1.61.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
